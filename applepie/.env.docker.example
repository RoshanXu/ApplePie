# ============================================================
# ApplePie — Docker 部署环境变量
#
# 使用方法:
#   1. 复制此文件为 .env（与 docker-compose.yml 同目录）
#   2. 填写下方的配置项（必填项已标注）
#   3. 运行: docker compose up -d
# ============================================================

# ---- Database (一般无需修改) ----
DB_USER=postgres
DB_PASSWORD=自行设置密码
DB_NAME=applepie

# ---- App 端口 ----
APP_PORT=3000

# ---- Auth Secret (必填 — 用于 JWT 签名) ----
# 生成方式: openssl rand -hex 32
AUTH_SECRET=请生成一个随机字符串_至少32字符

# ---- AI: 文本模型 — DeepSeek v4-pro (必填) ----
TEXT_BASE_URL=https://api.deepseek.com/v1
TEXT_API_KEY=sk-your-deepseek-api-key
TEXT_MODEL=deepseek-v4-pro

# ---- AI: 视觉识别 — 豆包 Doubao (必填) ----
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_API_KEY=your-doubao-ark-api-key
VISION_MODEL=doubao-seed-2-0-mini-260428

# ---- AI: 图片生成 — 豆包 Seedream (必填) ----
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
IMAGE_API_KEY=your-doubao-ark-api-key
IMAGE_MODEL=doubao-seedream-5-0-260128

# ---- TTS: 语音合成 (可选) ----
TTS_BASE_URL=
TTS_API_KEY=
TTS_SPEECH_MODEL=

# ---- 开发/调试 ----
MOCK_IMAGE=false
IMAGE_TIMEOUT_MS=30000
IMAGE_HEDGE_MS=15000
