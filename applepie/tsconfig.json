{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@applepie/*": ["./lib/applepie/*"],
      "@infiplot/engine": ["./lib/engine/index.ts"],
      "@infiplot/engine/*": ["./lib/engine/*"],
      "@infiplot/ai-client": ["./lib/ai-client/index.ts"],
      "@infiplot/ai-client/*": ["./lib/ai-client/*"],
      "@infiplot/types": ["./lib/types/index.ts"],
      "@infiplot/tts-client": ["./lib/tts-client/index.ts"],
      "@infiplot/tts-client/*": ["./lib/tts-client/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
