# ===== Database =====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/applepie"

# ===== Auth (JWT signing secret — generate with: openssl rand -hex 32) =====
AUTH_SECRET="your-secret-key-at-least-32-chars"

# ===== AI: Text — DeepSeek v4-pro =====
# 用途: 游戏编剧(Writer agent)、课表结构化解析、游戏结果分析
TEXT_BASE_URL="https://api.deepseek.com/v1"
TEXT_API_KEY="sk-your-deepseek-key"
TEXT_MODEL="deepseek-v4-pro"

# ===== AI: Vision — 豆包 Doubao (多模态识别) =====
# 用途: 游戏内点击解析、OCR 文字提取、图片/PDF 内容识别
VISION_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
VISION_API_KEY="your-doubao-ark-key"
VISION_MODEL="doubao-seed-2-0-mini-260428"

# ===== AI: Image — 豆包 Doubao Seedream (游戏场景图) =====
# 用途: 游戏场景背景图生成，OpenAI 兼容协议
IMAGE_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
IMAGE_API_KEY="your-doubao-ark-key"
IMAGE_MODEL="doubao-seedream-5-0-260128"

# ===== Development =====
MOCK_IMAGE=false

# ===== OCR & ASR (计划集成，尚未部署) =====
# OCR: PaddleOCR + PP-Structure (Apache 2.0) — 中文表格识别
#   pip install paddlepaddle paddleocr
# PDF: Camelot (MIT) — 规则PDF表格提取
#   pip install camelot-py
# ASR 移动端: SenseVoice-Small (234M) + sherpa-onnx (Apache 2.0)
# ASR 服务端: FireRedASR v2 / Qwen3-ASR (Apache 2.0)
#   参考: research/课程表识别与语音识别开源方案调研.md

# Image generation tuning (only when MOCK_IMAGE=false)
IMAGE_TIMEOUT_MS=30000
IMAGE_HEDGE_MS=15000

# ===== Optional: TTS (leave unset to disable voice) =====
# TTS_BASE_URL="https://tts-provider.example.com/v1"
# TTS_API_KEY="your-tts-key"
# TTS_SPEECH_MODEL="tts-model-name"
